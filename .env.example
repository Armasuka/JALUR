# ── Database (Turso / SQLite) ────────────────────────────────────────────────
# Get credentials at: https://console.turso.tech
#
# For LOCAL development with Turso CLI:
#   1. Install: brew install tursodatabase/tap/turso (macOS) or see https://turso.tech/tutorials/getting-started
#   2. Create db:  turso db create my-app
#   3. Dev URL:    turso dev url
#   4. Auth token: turso db show my-app --kV
#
# For REMOTE (production/edge):
#   1. Create:    turso db create my-app
#   2. Get URL:   turso db show my-app
#   3. Get token: turso db tokens create my-app
DATABASE_URL=libsql://your-db-name.turso.io
DATABASE_AUTH_TOKEN=your-auth-token-here

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Ultralytics YOLO ─────────────────────────────────────────────────────────
ULTRALYTICS_API_KEY=

# ── Supabase (auth + storage) ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── SMTP Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-password

# ── App ──────────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:3000
